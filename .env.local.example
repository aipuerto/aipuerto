# ================================================================
# aipuerto.com — Ortam Değişkenleri Şablonu
# Bu dosyayı .env.local olarak kopyalayın ve değerleri doldurun
# ================================================================

# ── Supabase ────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Stripe ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price ID'leri — Tekli Hizmetler
STRIPE_PRICE_KARTVIZIT=price_...
STRIPE_PRICE_DRIVE_OCR=price_...

# Stripe Price ID'leri — Paketler (Frontend için public)
NEXT_PUBLIC_STRIPE_PRICE_STARTER=price_...
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_...
NEXT_PUBLIC_STRIPE_PRICE_BUSINESS=price_...

# ── Şifreleme ───────────────────────────────────────────────────
# 32 byte = 64 hex karakter
# Üretmek için: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_32_byte_hex_key_here

# ── n8n ─────────────────────────────────────────────────────────
N8N_BASE_URL=https://n8n.sizin-domain.com
N8N_API_KEY=...

# ── WhatsApp ────────────────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=905XXXXXXXXX
NEXT_PUBLIC_WHATSAPP_MESSAGE=Merhaba, aipuerto.com hakkında bilgi almak istiyorum.

# ── Site ────────────────────────────────────────────────────────
NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=tr
NEXT_PUBLIC_LOCALES=tr,en
